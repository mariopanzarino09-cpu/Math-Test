<!DOCTYPE html>
<html>
<head>
  <title>Math Quiz</title>
</head>
<body>

<!-- START OF MATH TEST -->

<h2>Math Quiz</h2>

<form>

  <!-- Name Field -->
  <label for="name">Enter your name:</label><br>
  <input type="text" id="name" name="name"><br><br>

  <!-- Multiple Choice Question 1 -->
  <p>1. What is 5 + 3?</p>
  <input type="radio" name="q1" value="6"> 6<br>
  <input type="radio" name="q1" value="8"> 8<br>
  <input type="radio" name="q1" value="10"> 10<br><br>

  <!-- Multiple Choice Question 2 -->
  <p>2. What is 10 &times; 2?</p>
  <input type="radio" name="q2" value="12"> 12<br>
  <input type="radio" name="q2" value="20"> 20<br>
  <input type="radio" name="q2" value="25"> 25<br><br>

  <!-- Multiple Choice Question 3 -->
  <p>3. What is 15 &divide; 3?</p>
  <input type="radio" name="q3" value="3"> 3<br>
  <input type="radio" name="q3" value="5"> 5<br>
  <input type="radio" name="q3" value="6"> 6<br><br>

  <!-- Word Problem -->
  <p>4. Word Problem:</p>
  <p>If you have 4 apples and you buy 6 more, how many apples do you have in total? Explain your answer.</p>
  <textarea name="wordProblem" rows="4" cols="50"></textarea><br><br>

  <!-- Submit Button -->
  <input type="submit" value="Submit Test">

</form>

<!-- END OF MATH TEST -->

</body>
</html>
